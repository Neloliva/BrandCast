# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Postgres connection string for Drizzle migrations)
DATABASE_URL=

# LLM provider (decide later — defaults to Anthropic)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Optional: override the Anthropic model (defaults to claude-sonnet-4-5).
# Use an alias your account can access, e.g. claude-sonnet-4-6, claude-sonnet-4-5,
# claude-3-7-sonnet-20250219, or claude-3-5-sonnet-latest.
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="BrandCast <hello@yourdomain.com>"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
