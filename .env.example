# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Postgres connection string for Drizzle migrations)
DATABASE_URL=

# LLM providers — only the keys for providers you actually pick in the UI need to be set.
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
PERPLEXITY_API_KEY=
# Optional: override the Anthropic default model (used as fallback).
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="BrandCast <hello@yourdomain.com>"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
